# ── POLITICA DE LISTA BLANCA (WHITELIST) ──────────────────────
# Ignorar todo por defecto en la raíz
/*

# ── EXCEPCIONES: ARCHIVOS PERMITIDOS EN LA RAÍZ ──────────────
!/README.md
!/ml-service/
!/docker-compose.yml
!/.env.example
!/.gitignore

# ── PYTHON / ML-SERVICE (IGNORAR LOCALES) ─────────────────────
**/__pycache__/
**/*.py[cod]
ml-service/**/__pycache__/
ml-service/**/*.py[cod]
ml-service/venv/
ml-service/.venv/
ml-service/env/
ml-service/ENV/
ml-service/model_artifacts/
ml-service/logs.txt
ml-service/tmp_fix.py
ml-service/pytest.ini
ml-service/tests/
ml-service/restore_keys.py
ml-service/fix_admin_auth.py
ml-service/app/fix_admin_auth.py

# ── ARCHIVOS DE SISTEMA E IDEs ───────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.code-workspace
.agent/
.gemini/
tmp/
.docker/

# ── VARIABLES Y SECRETOS (NUNCA SUBIR) ────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.cert
secrets.json
.secrets/
