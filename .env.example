# ==============================================================================
# 🛡️  SENTINEL ML - Configuración de Entorno (DEVELOPMENT)
# ==============================================================================
# Renombrar este archivo a `.env` y ajustar los valores requeridos.
#
# ADVERTENCIA: NUNCA hagas commit del archivo `.env` real a control de versiones.
# ==============================================================================

# ── 1. Entorno de Aplicación ──────────────────────────────────────────────────
# DEVELOPMENT (default) o PRODUCTION. 
# En PRODUCTION fallará si las claves JWT / SECRET_KEY están vacías.
APP_ENV=DEVELOPMENT

# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── 2. Credenciales y Seguridad ───────────────────────────────────────────────
# LLAVES SECRETAS PARA FIRMA (Requeridas en PRODUCTION)
# Generar seguras con: openssl rand -hex 32
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256

# Origenes permitidos para la API (separados por comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── 3. Base de Datos (PostgreSQL + TimescaleDB) ───────────────────────────────
# Credenciales del contenedor de Base de datos
DB_NAME=ml_features
DB_USER=ml
DB_PASSWORD=cambiame_por_favor

# URL completa de conexión de SQLAlchemy
DATABASE_URL=postgresql://ml:cambiame_por_favor@ml-db:5432/ml_features

# ── 4. Caché de Mensajes y Broker (Redis) ─────────────────────────────────────
# Contraseña para asegurar Redis (REQUERIDA)
REDIS_PASSWORD=cambiame_por_favor
# URL completa (redis://[:password]@host:port/db)
REDIS_URL=redis://:cambiame_por_favor@redis:6379/0

# ── 5. Integración con Frontend/GRC ───────────────────────────────────────────
# Dejar vacío si solo se usa Sentinel-ML standalone / DUMMY
DEV_GRC_URL=
DEV_GRC_API_KEY=
DEV_GRC_API_SECRET=

# Modo de Inferencia (ML)
# Opciones: 
# - DUMMY  (No hace inferencia, siempre fake score = 0.5)
# - SHADOW (Corre modelos reales pero no interfiere en red)
# - LIVE   (Previene / Alerta activa)
MODEL_MODE=SHADOW
