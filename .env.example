# Sentinel ML Service — Plantilla de variables de entorno
# 1. Copiar este archivo: cp .env.example .env
# 2. Completar los valores reales
# NUNCA subir el archivo .env al repositorio

# -- Infraestructura --
DATABASE_URL=postgresql://ml:ml@ml-db:5432/ml_features
REDIS_URL=redis://ml-redis:6379/0
APP_ENV=DEVELOPMENT
LOG_LEVEL=INFO
MODEL_ARTIFACTS_PATH=/app/model_artifacts

# -- Modelo ML --
# DUMMY=solo conectividad  SHADOW=sin impacto real  LIVE=gobernanza completa
MODEL_MODE=DUMMY

# -- Integracion GRC -- (rellenar con los valores reales de tu instancia GRC)
DEV_GRC_URL=https://tu-instancia-grc.com
DEV_GRC_API_KEY=
DEV_GRC_API_SECRET=

# -- Seguridad --
# Generar con: openssl rand -hex 32
SECRET_KEY=
# Generar con: openssl rand -hex 64
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# -- CORS -- (origenes separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -- Circuit Breaker --
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_S=60

# -- MLOps --
SHAP_TIMEOUT_S=30
RETENTION_DAYS=90

# -- Threat Intelligence (opcional - dejar vacio para deshabilitar) --
# Registro gratuito en: https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=

# -- Kafka (opcional - dejar vacio para usar Redis Queue por defecto) --
KAFKA_BROKER_URL=
KAFKA_INGEST_TOPIC=sentinel.ingest

# -- Simulator (solo testing) --
SIM_CLIENT_ID=sim-client
SIM_CLIENT_SECRET=sim-secret-dev
