# Sentinel ML Service — Variables de entorno
# Copiar a .env y ajustar antes de levantar con docker-compose
# NUNCA subir el archivo .env al repositorio

# ── Modo del modelo ──────────────────────────────────────────
# DUMMY   = Fase II - solo valida conectividad, no requiere modelo entrenado
# SHADOW  = Fase III - genera recomendaciones sin impacto real en el GRC
# LIVE    = Fase IV - gobernanza completa activa, HMAC obligatorio
MODEL_MODE=DUMMY

# ── Seguridad ────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=cambiar-en-produccion-usar-openssl-rand-hex-32

# ── Threat Intelligence (opcional) ────────────────────────────
# Registrarse gratis en: https://www.abuseipdb.com/
# Dejar vacío para deshabilitar la consulta a AbuseIPDB
ABUSEIPDB_API_KEY=

# ── Circuit Breaker ───────────────────────────────────────────
# CB_FAILURE_THRESHOLD=5       # número de fallos antes de abrir
# CB_RECOVERY_TIMEOUT_S=60     # segundos antes de intentar HALF_OPEN

# ── Simulator (solo para testing) ────────────────────────────
SIM_CLIENT_ID=sim-client
SIM_CLIENT_SECRET=sim-secret-dev
